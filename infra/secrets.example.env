# Template for /etc/radiotelescope/secrets.env on the Pi.
#
# DO NOT COMMIT the real file. Copy this to secrets.env, fill in real
# values, install at /etc/radiotelescope/secrets.env (mode 0600, owned by
# the telescope user), and reference these vars from config.toml via the
# ${VAR_NAME} substitution that load_config supports.
#
# Generate fresh secrets locally with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
#
# The backend's public_exposure_errors() startup gate refuses to come up
# with any placeholder value still present.

# Signs the queue session cookie. Must be at least 32 random characters.
RT_QUEUE_COOKIE_SECRET=replace-me-with-a-token_urlsafe-48-output

# Signs login session cookies if auth.enabled = true.
RT_AUTH_SECRET_KEY=replace-me-with-a-token_urlsafe-48-output

# Cloudflare Turnstile site + secret keys. Get them from
# https://dash.cloudflare.com/?to=/:account/turnstile.
RT_TURNSTILE_SITE_KEY=0x4AAAAAAA-replace-me
RT_TURNSTILE_SECRET_KEY=0x4AAAAAAA-replace-me
